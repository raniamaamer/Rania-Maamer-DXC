{
  "id": null,
  "uid": "django-portal",
  "title": "DXC Portal - Django Metrics",
  "tags": ["django", "dxc", "backend"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Requêtes HTTP / seconde",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "rate(django_http_requests_total_by_method_total[5m])",
        "legendFormat": "{{method}}"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 50}] }
      }}
    },
    {
      "id": 2,
      "title": "Latence moyenne (ms)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "rate(django_http_requests_latency_seconds_sum[5m]) / rate(django_http_requests_latency_seconds_count[5m]) * 1000",
        "legendFormat": "Latence moy."
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 200}, {"color": "red", "value": 500}] }
      }}
    },
    {
      "id": 3,
      "title": "Erreurs HTTP 4xx / 5xx",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(django_http_responses_total_by_status_total{status=~\"4..|5..\"}[5m]))",
        "legendFormat": "Erreurs"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}] }
      }}
    },
    {
      "id": 4,
      "title": "Connexions DB actives",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "pg_stat_database_numbackends{datname=\"dxc_kpi_db\"}",
        "legendFormat": "Connexions"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 20}] }
      }}
    },
    {
      "id": 5,
      "title": "Requêtes HTTP par statut (timeline)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "rate(django_http_responses_total_by_status_total[5m])",
        "legendFormat": "HTTP {{status}}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 6,
      "title": "Latence par endpoint (p95)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(django_http_requests_latency_seconds_bucket[5m]))",
        "legendFormat": "p95 latency"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "title": "Transactions PostgreSQL / seconde",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(pg_stat_database_xact_commit{datname=\"dxc_kpi_db\"}[5m])", "legendFormat": "Commits/s" },
        { "expr": "rate(pg_stat_database_xact_rollback{datname=\"dxc_kpi_db\"}[5m])", "legendFormat": "Rollbacks/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 8,
      "title": "Taille base de données (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "pg_database_size_bytes{datname=\"dxc_kpi_db\"} / 1024 / 1024",
        "legendFormat": "dxc_kpi_db (MB)"
      }],
      "fieldConfig": { "defaults": { "unit": "MB" } }
    }
  ]
}