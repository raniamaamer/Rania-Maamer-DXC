# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Environnement virtuel ─────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Variables d'environnement ─────────────────────────────────
.env
.env.*                         # ← ajouté : .env.prod, .env.local, etc.

# ── Données / Notebooks ───────────────────────────────────────
ML/data/
ML/*.ipynb
ml_output/                     # ← ajouté : outputs ML potentiellement lourds
data/                          # ← ajouté : le dossier ./data monté en volume de toute façon
*.csv                          # ← ajouté : incident_sla.csv peut être énorme
*.log                          # ← ajouté : logs Django/gunicorn

# ── Tests / Coverage ─────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
coverage.xml
tests/                         # ← ajouté : inutile en prod

# ── IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo                          # ← ajouté

# ── Git ───────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes                 # ← ajouté

# ── Docker ───────────────────────────────────────────────────
Dockerfile
Dockerfile.*                   # ← ajouté : Dockerfile.ml, Dockerfile.dev
.dockerignore
docker-compose*.yml            # ← ajouté : inutile dans le conteneur

# ── Fichiers statiques collectés ──────────────────────────────
staticfiles/

# ── OS ────────────────────────────────────────────────────────
.DS_Store                      # ← ajouté
Thumbs.db                      # ← ajouté

# ── Docs ──────────────────────────────────────────────────────
*.md                           # ← ajouté
docs/                          # ← ajouté