FROM python:3.9-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH="/app"

WORKDIR /app

# ── Upgrade pip + toutes les dépendances en une seule couche ──────
COPY requirements.txt .
RUN pip install --upgrade pip && \
    pip install --no-cache-dir \
        numpy==1.26.4 \
        pandas==2.2.2 \
        matplotlib==3.8.4 \
        seaborn==0.13.2 && \
    pip install --no-cache-dir -r requirements.txt

# ── Code source ───────────────────────────────────────────────────
COPY backend/ .

# ── Données CSV — copiées dans l'image au moment du build ─────────
COPY data/ /app/data/

EXPOSE 8000

CMD ["gunicorn", "dxc_backend.wsgi:application", "--bind", "0.0.0.0:8000", "--workers", "3"]