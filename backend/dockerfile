FROM python:3.9-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH="/app"

WORKDIR /app

RUN pip install --upgrade pip

# ✅ requirements EN PREMIER → cache préservé si pas modifié
COPY requirements.txt .
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -r requirements.txt

# ✅ Installer CmdStan pour Prophet
RUN python -c "import cmdstanpy; cmdstanpy.install_cmdstan()"

# Code source après → re-build rapide si seulement le code change
COPY backend/ .
COPY data/ /app/data/

EXPOSE 8000

CMD ["gunicorn", "dxc_backend.wsgi:application", "--bind", "0.0.0.0:8000", "--workers", "3"]