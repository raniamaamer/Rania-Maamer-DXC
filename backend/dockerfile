FROM python:3.9-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH="/app"

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY backend/ .

# Supprimer le second WORKDIR — manage.py est déjà dans /app
EXPOSE 8000

CMD ["gunicorn", "dxc_backend.wsgi:application", "--bind", "0.0.0.0:8000", "--workers", "3"]